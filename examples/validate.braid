# A validation railway: each >=> stage routes hit | miss, misses fall
# through untouched. Continuation lines lead with >=>, like >> and |.

def double = 2 _ >> *   # not in the prelude

## even, under 100, then doubled and declared ok
def process =
    even?
    >=> _ 100 >> less?
    >=> double >> ok

4 >> process >> print     # in1(8)
7 >> process >> print     # in2(7)
120 >> process >> print   # in2(120)
