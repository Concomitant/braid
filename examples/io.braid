# The full circle: generate code, save it to disk, load it back,
# parse it, run it. IO edges are railway stages, so the pipeline is
# one >=> chain until the eval.

[dup >> *] >> reflect >>
    ((c -> "/tmp/braid-square.braid" (c >> unparse) >> writeFile) | in2) >> merge >>
    ("saved" >> print | print) >> forget

("/tmp/braid-square.braid" >> readFile >=> parse) >>
    ((c -> c (7) >> evalCode >> print) | print) >> forget    # in1(49)
