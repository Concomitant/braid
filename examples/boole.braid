def not = (in2 | in1) >> merge
def small? = _ 10 >> lt? >> (_ drop | _ drop)
def big? = small? >> not

def evenAndSmall? = even? >> (small? | in2) >> merge
def oddOrZero? = odd? >> (in1 | zero?) >> merge

4 >> evenAndSmall? >> print
40 >> evenAndSmall? >> print
7 >> oddOrZero? >> print
0 >> oddOrZero? >> print
8 >> oddOrZero? >> print
12 >> big? >> print
